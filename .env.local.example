# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Google Cloud Text-to-Speech API key
# Console: https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
GOOGLE_TTS_API_KEY=your_google_tts_api_key

# ElevenLabs Music API (optional, BGM 자동 생성용)
# Dashboard: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Supabase Auth (로그인)
# Dashboard: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
